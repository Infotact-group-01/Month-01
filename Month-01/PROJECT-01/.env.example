# ─────────────────────────────────────────────────────────────────────────────
# .env.example — TIP Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=tip
MONGODB_COLLECTION=indicators

# ── Elasticsearch & Kibana (via Docker) ────────────────────────────────────────
ELASTICSEARCH_URI=http://localhost:9200
ES_USER=elastic
ELASTIC_PASSWORD=your_elastic_password_here
KIBANA_SYSTEM_PASSWORD=your_kibana_password_here

# ── Live Threat Feed API Keys ─────────────────────────────────────────────────
# AbuseIPDB — free registration at https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# AlienVault OTX — free registration at https://otx.alienvault.com
OTX_API_KEY=your_otx_api_key_here

# ── Rollback API (optional overrides) ────────────────────────────────────────
# ROLLBACK_API_HOST=127.0.0.1
# ROLLBACK_API_PORT=5050

# Rollback API Key — if set, all /api/* endpoints require the header:
#   X-API-Key: <your_key>
# Leave empty (or unset) to run without authentication (localhost-only default).
# ROLLBACK_API_KEY=your_secret_api_key_here

# ── Policy Enforcer (optional overrides) ─────────────────────────────────────
# ENFORCER_THRESHOLD=90       # Block IPs with risk_score >= this value
# ENFORCER_INTERVAL=60        # Seconds between enforcement cycles
# ENFORCER_MAX_IPS=1000       # Max IPs queried from Elasticsearch per cycle
